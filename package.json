{
  "name": "@peoplepower/webcore",
  "version": "3.0.0",
  "description": "Client JS/TS SDK for Care Daily Cloud API",
  "keywords": [
    "WebCore",
    "Care Daily",
    "Client SDK",
    "Application API"
  ],
  "main": "dist/webcore.cjs.js",
  "module": "dist/webcore.esm.js",
  "typings": "dist/types/webcore.d.ts",
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "contributors": [
    {
      "name": "Aleksei Tolkachev",
      "email": "aleksei@caredaily.ai"
    },
    {
      "name": "Max Filatov",
      "email": "max@caredaily.ai"
    }
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/peoplepower/webcore.git"
  },
  "license": "Apache-2.0",
  "packageManager": "pnpm@10.29.3",
  "engines": {
    "node": ">=20.15.1 <21.0.0"
  },
  "scripts": {
    "prebuild": "rimraf ./dist",
    "build": "vite build && pnpm run build:types",
    "build:types": "tsc --project tsconfig.json",
    "test:build": "vitest run ./tests/build.test.ts",
    "lint": "eslint"
  },
  "devDependencies": {
    "@eslint/js": "9.39.2",
    "@types/node": "20.15.0",
    "@types/qs": "6.14.0",
    "eslint": "9.39.2",
    "eslint-config-prettier": "10.1.8",
    "prettier": "3.8.1",
    "rimraf": "6.1.2",
    "typescript": "5.6.3",
    "typescript-eslint": "8.55.0",
    "vite": "6.2.3",
    "vitest": "3.1.1"
  },
  "dependencies": {
    "axios": "1.13.5",
    "qs": "6.14.1"
  }
}

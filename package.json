{
  "name": "@peoplepower/webcore",
  "version": "3.2.0",
  "description": "Client JS/TS SDK for Care Daily Cloud API",
  "type": "module",
  "keywords": [
    "WebCore",
    "Care Daily",
    "Client SDK",
    "Application API"
  ],
  "main": "dist/webcore.cjs.js",
  "module": "dist/webcore.esm.js",
  "browser": "dist/webcore.umd.js",
  "typings": "dist/types/webcore.d.ts",
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "contributors": [
    {
      "name": "Aleksei Tolkachev",
      "email": "aleksei@caredaily.ai"
    },
    {
      "name": "Max Filatov",
      "email": "max@caredaily.ai"
    }
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/peoplepower/webcore.git"
  },
  "license": "Apache-2.0",
  "packageManager": "pnpm@11.1.3",
  "engines": {
    "node": ">=22.13.0 <23.0.0"
  },
  "scripts": {
    "prebuild": "rimraf ./dist",
    "build": "vite build && pnpm run build:types",
    "build:types": "tsc --project tsconfig.json",
    "test:build": "vitest run ./tests/build.test.ts",
    "lint": "oxlint"
  },
  "devDependencies": {
    "@types/node": "22.19.19",
    "@types/qs": "6.15.1",
    "oxlint": "1.66.0",
    "rimraf": "6.1.2",
    "tslib": "2.8.1",
    "typescript": "5.9.3",
    "vite": "8.0.11",
    "vitest": "4.1.5"
  },
  "dependencies": {
    "axios": "1.15.2",
    "qs": "6.15.2"
  }
}
